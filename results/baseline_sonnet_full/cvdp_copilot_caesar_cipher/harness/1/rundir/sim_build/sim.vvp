S_0xaaaac306a550 .scope package, "$unit" "$unit" 2 1;
 .timescale -9 -9;
S_0xaaaac306a6e0 .scope module, "caesar_cipher" "caesar_cipher" 3 1;
 .timescale -9 -9;
    .port_info 0 /INPUT 8 "input_char";
    .port_info 1 /INPUT 4 "key";
    .port_info 2 /OUTPUT 8 "output_char";
o0xffff9d11f018 .functor BUFZ 8, c4<zzzzzzzz>; HiZ drive
v0xaaaac306a8e0_0 .net "input_char", 7 0, o0xffff9d11f018;  0 drivers
o0xffff9d11f048 .functor BUFZ 4, c4<zzzz>; HiZ drive
v0xaaaac30b48e0_0 .net "key", 3 0, o0xffff9d11f048;  0 drivers
v0xaaaac30b49c0_0 .var "output_char", 7 0;
E_0xaaaac30a3b50 .event anyedge, v0xaaaac306a8e0_0, v0xaaaac30b48e0_0;
    .scope S_0xaaaac306a6e0;
T_0 ;
Ewait_0 .event/or E_0xaaaac30a3b50, E_0x0;
    %wait Ewait_0;
    %load/vec4 v0xaaaac306a8e0_0;
    %cmpi/u 65, 0, 8;
    %flag_inv 5; GE is !LT
    %flag_get/vec4 5;
    %jmp/0 T_0.2, 5;
    %load/vec4 v0xaaaac306a8e0_0;
    %cmpi/u 90, 0, 8;
    %flag_get/vec4 4;
    %flag_get/vec4 5;
    %or;
    %and;
T_0.2;
    %flag_set/vec4 8;
    %jmp/0xz  T_0.0, 8;
    %load/vec4 v0xaaaac306a8e0_0;
    %subi 65, 0, 8;
    %pushi/vec4 0, 0, 4;
    %load/vec4 v0xaaaac30b48e0_0;
    %concat/vec4; draw_concat_vec4
    %add;
    %pushi/vec4 26, 0, 8;
    %mod;
    %addi 65, 0, 8;
    %store/vec4 v0xaaaac30b49c0_0, 0, 8;
    %jmp T_0.1;
T_0.0 ;
    %load/vec4 v0xaaaac306a8e0_0;
    %cmpi/u 97, 0, 8;
    %flag_inv 5; GE is !LT
    %flag_get/vec4 5;
    %jmp/0 T_0.5, 5;
    %load/vec4 v0xaaaac306a8e0_0;
    %cmpi/u 122, 0, 8;
    %flag_get/vec4 4;
    %flag_get/vec4 5;
    %or;
    %and;
T_0.5;
    %flag_set/vec4 8;
    %jmp/0xz  T_0.3, 8;
    %load/vec4 v0xaaaac306a8e0_0;
    %subi 97, 0, 8;
    %pushi/vec4 0, 0, 4;
    %load/vec4 v0xaaaac30b48e0_0;
    %concat/vec4; draw_concat_vec4
    %add;
    %pushi/vec4 26, 0, 8;
    %mod;
    %addi 97, 0, 8;
    %store/vec4 v0xaaaac30b49c0_0, 0, 8;
    %jmp T_0.4;
T_0.3 ;
    %load/vec4 v0xaaaac306a8e0_0;
    %store/vec4 v0xaaaac30b49c0_0, 0, 8;
T_0.4 ;
T_0.1 ;
    %jmp T_0;
    .thread T_0, $push;
