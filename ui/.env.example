# Copy to .env (or place at repo root) and fill in values

# Anthropic API key — required for Claude Sonnet backend and spec clarification
ANTHROPIC_API_KEY=sk-ant-...

# vLLM OpenAI-compatible endpoint — required for Qwen RL v2 backend
# Default: http://localhost:8000/v1
VLLM_ENDPOINT=http://localhost:8000/v1
